@model Afri.Models.User
@{
    Layout = null;
}
@if (ViewBag.Error != null)
{
    <div class="alert alert-danger">
        @ViewBag.Error
    </div>
}
<!DOCTYPE html>
<html lang="en">
<head>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <style>
        .split-container {
            height: 100vh;
            display: flex;
        }

        .image-side {
            flex: 1;
            background: linear-gradient(rgba(15, 23, 42, 0.7), rgba(15, 23, 42, 0.7)), url('https://images.unsplash.com/photo-1523240795612-9a054b0db644?q=80&w=2070');
            background-size: cover;
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            padding: 60px;
        }

        .form-side {
            width: 550px;
            display: flex;
            align-items: center;
            justify-content: center;
            background: white;
            padding: 50px;
            overflow-y: auto;
        }

        .logo-3d {
            width: 100px;
            filter: drop-shadow(0 10px 15px rgba(0,0,0,0.2));
        }
    </style>
</head>
<body>
    <div class="split-container">
        <div class="image-side d-none d-md-flex text-center">
            <div>
                <img src="~/images/logo.png" class="logo-3d mb-4">
                <h1 class="display-4 fw-bold">Start Your Future.</h1>
                <p class="h4 fw-light opacity-75">Join thousands of students learning in their native languages with AI.</p>
            </div>
        </div>
        <div class="form-side">
            <div class="w-100">
                <h2 class="fw-bold mb-1">Create Account</h2>
                <p class="text-muted mb-4">It's free and takes less than a minute.</p>

                <form asp-action="Signup" method="post">
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-2"></div>
                    <div class="mb-3">
                        <label class="form-label small fw-bold">Full Name</label>
                        <input asp-for="FullName" class="form-control form-control-lg bg-light border-0" placeholder="Abebe Balcha" required />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Email</label>
                            <input asp-for="Email" class="form-control form-control-lg bg-light border-0" placeholder="name@email.com" required />
                            <span asp-validation-for="Email" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Phone</label>
                            <input asp-for="PhoneNumber" class="form-control form-control-lg bg-light border-0" placeholder="09..." />
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label small fw-bold">Gender</label>
                            <select asp-for="Gender" class="form-select form-select-lg bg-light border-0">
                                <option value="Male">Male</option>
                                <option value="Female">Female</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label small fw-bold">Password</label>
                            <input name="password" type="password" class="form-control form-control-lg bg-light border-0" placeholder="••••••••" required />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow-sm fw-bold mb-3" style="background: #4e73df;">Register Now</button>
                    <p class="text-center small">Already have an account? <a href="/Users/Signin" class="fw-bold text-decoration-none">Sign In</a></p>
                </form>
            </div>
        </div>
    </div>
</body>
</html>