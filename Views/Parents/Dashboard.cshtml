@model IEnumerable<Afri.Models.User>

@{
    ViewData["Title"] = "Parent Dashboard";
}

<div class="container-fluid py-4 min-vh-100">
    <div class="row align-items-center mb-4">
        <div class="col-8">
            <h2 class="fw-bold mb-1">Parent Dashboard</h2>
            <p class="text-muted mb-0">Track your children's learning progress</p>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info py-4 text-center rounded-4 border-0 shadow-sm">
            <i class="bi bi-info-circle display-4 d-block mb-3"></i>
            <h5>No children associated with your account yet.</h5>
            <p class="text-muted">Please contact administration to link your children's accounts.</p>
        </div>
    }
    else
    {
        <div class="row g-4">
            @foreach (var child in Model)
            {
                <div class="col-md-6 col-lg-4">
                    <div class="card h-100 border-0 shadow-sm rounded-4 hover-lift">
                        <div class="card-body p-4">
                            <div class="d-flex align-items-center mb-4">
                                <img src="https://ui-avatars.com/api/?name=@child.FullName&background=f0fdf4&color=166534&bold=true" class="rounded-circle shadow-sm me-3" width="50" height="50" alt="@child.FullName">
                                <div>
                                    <h5 class="fw-bold mb-0">@child.FullName</h5>
                                    <span class="badge bg-success bg-opacity-10 text-success rounded-pill">Student</span>
                                </div>
                            </div>
                            
                            <hr class="opacity-10 my-3">
                            
                            <div class="d-flex justify-content-between text-muted mb-2">
                                <small><i class="bi bi-journal-check me-1"></i> Lessons Completed</small>
                                <span class="fw-bold text-dark">@child.StudentProgresses.Count(p => p.CompletionStatus == "Completed")</span>
                            </div>
                            
                            <div class="d-flex justify-content-between text-muted mb-3">
                                <small><i class="bi bi-clipboard-check me-1"></i> Quizzes Taken</small>
                                <span class="fw-bold text-dark">@child.StudentQuizAttempts.Count()</span>
                            </div>

                            <a href="#child-@child.Id-details" class="btn btn-primary w-100 rounded-pill" data-bs-toggle="collapse">
                                View Details <i class="bi bi-chevron-down ms-1"></i>
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>

        @foreach (var child in Model)
        {
            <div id="child-@child.Id-details" class="collapse mt-4">
                <div class="card border-0 shadow-sm rounded-4">
                    <div class="card-header bg-white p-4 border-bottom">
                        <h4 class="fw-bold mb-0">@child.FullName's Activity</h4>
                    </div>
                    <div class="card-body p-4">
                        <div class="row g-4">
                            <div class="col-md-6">
                                <h5 class="fw-bold text-primary mb-3"><i class="bi bi-clock-history me-2"></i>Recent Activity Logs</h5>
                                @if (child.StudentActivityLogs.Any())
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach(var activity in child.StudentActivityLogs)
                                        {
                                            <li class="list-group-item bg-transparent px-0 py-3 text-muted">
                                                <div class="fs-6 text-dark fw-medium">@activity.ActivityType</div>
                                                <small><i class="bi bi-calendar-event me-1"></i> @activity.ActivityDate?.ToString("MMM dd, yyyy h:mm tt")</small>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No recent activity found.</p>
                                }
                            </div>
                            <div class="col-md-6">
                                <h5 class="fw-bold text-success mb-3"><i class="bi bi-bar-chart-fill me-2"></i>Recent Quizzes</h5>
                                @if (child.StudentQuizAttempts.Any())
                                {
                                    <ul class="list-group list-group-flush">
                                        @foreach(var quiz in child.StudentQuizAttempts.OrderByDescending(q => q.AttemptDate).Take(5))
                                        {
                                            <li class="list-group-item bg-transparent px-0 py-3">
                                                <div class="d-flex justify-content-between align-items-center">
                                                    <span class="fs-6 text-dark fw-medium">@quiz.Quiz.Title</span>
                                                    <span class="badge bg-primary rounded-pill fs-6 px-3 py-2">Score: @quiz.Score</span>
                                                </div>
                                                <small class="text-muted"><i class="bi bi-calendar me-1"></i> @quiz.AttemptDate?.ToString("MMM dd, yyyy h:mm tt")</small>
                                            </li>
                                        }
                                    </ul>
                                }
                                else
                                {
                                    <p class="text-muted">No recent quizzes found.</p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>
