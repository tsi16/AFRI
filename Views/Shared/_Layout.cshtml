@using Afri.Utilities
@inject Afri.Utilities.CurrentUser CurrentUser
@inject Afri.Models.AFRILEARNContext _context
@{
    int userId = CurrentUser.GetUserId();
    var loggedInUser = _context.Users.FirstOrDefault(u => u.Id == userId);
    string displayName = loggedInUser != null ? $"{loggedInUser.FullName}" : "Guest Student";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>AfriLearn | Professional AI Tutor</title>


   
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />

        <title>@ViewData["Title"] — Ethiopia's #1 AI Learning Platform</title>
        <meta name="description" content="Break the language barrier. Master Grade 9–12 subjects with AI tutors who speak Amharic, Afan Oromo, and English." />

        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&display=swap" rel="stylesheet">

        <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />

        <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
  


    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">

    @if (userId == 0)
    {
        <style>
            html, body {
                margin: 0 !important;
                padding: 0 !important;
                width: 100%;
                overflow-x: hidden;
            }

            .main-content {
                padding: 0 !important;
                margin: 0 !important;
            }

            .container-fluid {
                padding-left: 0 !important;
                padding-right: 0 !important;
            }
        </style>
    }
    else
    {
        <style>
            :root {
                --sidebar-w: 280px;
                --primary: #4f46e5;
                --dark-nav: #0f172a;
            }

            html, body {
                background: #f8fafc !important;
                font-family: 'Inter', sans-serif;
                overflow-x: hidden;
                margin: 0;
                padding: 0;
            }

            .sidebar {
                width: var(--sidebar-w);
                height: 100vh;
                position: fixed;
                top: 0;
                left: 0;
                background: var(--dark-nav);
                color: white;
                z-index: 1050;
                box-shadow: 4px 0 15px rgba(0,0,0,0.05);
                transition: transform 0.3s ease;
            }

            .main-content {
                min-height: 100vh;
                margin-left: var(--sidebar-w) !important;
                display: flex;
                flex-direction: column;
                background: #f8fafc;
            }

            .nav-link {
                color: #94a3b8;
                padding: 12px 20px;
                display: flex;
                align-items: center;
                text-decoration: none;
                border-radius: 8px;
                transition: all 0.2s ease;
                font-weight: 500;
                margin-bottom: 4px;
            }

            .nav-link:hover, .nav-link.active {
                color: white;
                background: rgba(255,255,255,0.1);
            }
            .nav-link.active {
                border-left: 3px solid var(--primary);
                padding-left: 17px;
            }
            
            .nav-link i {
                font-size: 1.25rem;
                transition: transform 0.2s ease;
            }
            .nav-link:hover i {
                transform: scale(1.1);
            }

            .chat-window {
                position: fixed;
                bottom: 100px;
                right: 30px;
                width: 380px;
                height: 550px;
                background: white;
                border-radius: 20px;
                display: none;
                flex-direction: column;
                box-shadow: 0 15px 35px rgba(0,0,0,0.2);
                z-index: 2000;
                border: 1px solid #eee;
            }

            .ai-chat-float {
                position: fixed;
                bottom: 30px;
                right: 30px;
                z-index: 2000;
                transition: transform 0.3s;
            }
            .ai-chat-float:hover {
                transform: scale(1.05);
            }

            #chatMessages {
                flex-grow: 1;
                overflow-y: auto;
                padding: 20px;
                background: #f8f9fc;
            }
            
            /* Enhanced Card and Shadow styles globally for logged-in pages */
            .card {
                border: none;
                box-shadow: 0 4px 6px -1px rgba(0,0,0,0.05), 0 2px 4px -1px rgba(0,0,0,0.03);
                border-radius: 12px;
            }
        </style>
    }
</head>
<body>

    <!-- SIDEBAR (Only for logged-in users) -->
    @if (userId != 0)
    {
        <div class="sidebar d-flex flex-column">
            <div class="py-4 px-4 border-bottom border-light border-opacity-10 text-center">
                <a href="/Home" class="text-decoration-none">
                    <h4 class="fw-bold mb-0 text-white d-flex align-items-center justify-content-center">
                        <i class="bi bi-rocket-takeoff-fill text-primary me-2 fs-3"></i>
                        AfriLearn<span class="text-primary fs-3">.</span>
                    </h4>
                </a>
            </div>

            <nav class="nav flex-column flex-grow-1 px-3 py-4 overflow-y-auto">
                @{
                    var controller = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
                    var action = ViewContext.RouteData.Values["action"]?.ToString() ?? "";
                }
                <a class="nav-link @(controller == "Home" && (action == "Index" || string.IsNullOrEmpty(action)) ? "active" : "")" href="/Home">
                    <i class="bi bi-grid-1x2 me-3"></i> Dashboard
                </a>
                
                @if (CurrentUser.IsInstructor())
                {
                    <div class="text-uppercase text-secondary fw-bold mt-4 mb-2 px-3" style="font-size: 0.7rem; letter-spacing: 0.1em;">Teaching</div>
                    <a class="nav-link" href="/Subjects">
                        <i class="bi bi-journal-album me-3"></i> Subjects &amp; Topics
                    </a>
                    <a class="nav-link" href="/Subjects">
                        <i class="bi bi-play-btn me-3"></i> Lessons
                    </a>
                    <div class="text-uppercase text-secondary fw-bold mt-4 mb-2 px-3" style="font-size: 0.7rem; letter-spacing: 0.1em;">Assessments</div>
                    <a class="nav-link" href="/Quizs/Index">
                        <i class="bi bi-clipboard-check me-3"></i> Quizzes
                    </a>
                    <a class="nav-link" href="/Users">
                        <i class="bi bi-people me-3"></i> Users
                    </a>
                    <a class="nav-link" href="/AiinteractionFeedbacks/Index">
                        <i class="bi bi-chat-dots me-3"></i> AI Feedback
                    </a>
                }
                else if (CurrentUser.IsParent())
                {
                    <div class="text-uppercase text-secondary fw-bold mt-4 mb-2 px-3" style="font-size: 0.7rem; letter-spacing: 0.1em;">Parenting</div>
                    <a class="nav-link" href="/Parents/Dashboard">
                        <i class="bi bi-people-fill me-3"></i> My Children
                    </a>
                    <a class="nav-link" href="/Parents/Dashboard">
                        <i class="bi bi-graph-up me-3"></i> Activity Reports
                    </a>
                }
                else
                {
                    <div class="text-uppercase text-secondary fw-bold mt-4 mb-2 px-3" style="font-size: 0.7rem; letter-spacing: 0.1em;">Learning</div>
                    <a class="nav-link" href="/Subjects">
                        <i class="bi bi-journal-bookmark me-3"></i> Browse Subjects
                    </a>
                    <a class="nav-link" href="/StudentProgress">
                        <i class="bi bi-graph-up me-3"></i> My Progress
                    </a>
                    <div class="text-uppercase text-secondary fw-bold mt-4 mb-2 px-3" style="font-size: 0.7rem; letter-spacing: 0.1em;">Community</div>
                    <a class="nav-link" href="/Leaderboard">
                        <i class="bi bi-trophy me-3"></i> Leaderboard
                    </a>
                }
            </nav>

            <div class="p-4 border-top border-light border-opacity-10">
                <div class="d-flex align-items-center w-100 mb-3">
                    <img src="https://ui-avatars.com/api/?name=@displayName&background=4f46e5&color=fff&bold=true"
                         class="rounded-circle me-3 border border-2 border-opacity-25" width="45" height="45">
                    <div class="small overflow-hidden text-white flex-grow-1" style="line-height: 1.3;">
                        <span class="d-block text-truncate fw-bold fs-6">@displayName</span>
                        <span class="d-block text-white-50" style="font-size: 0.75rem;">@CurrentUser.GetUserRole()</span>
                    </div>
                </div>
                <a href="/Users/Logout" class="btn btn-outline-light btn-sm w-100 d-flex align-items-center justify-content-center opacity-75 hover-opacity-100 transition">
                    <i class="bi bi-box-arrow-right me-2"></i> Sign Out
                </a>
            </div>
        </div>
    }

    <!-- MAIN CONTENT -->
    <div class="main-content">
        @if (userId != 0)
        {
            <!-- TOP NAV FOR LOGGED IN USERS -->
            <nav class="navbar navbar-expand bg-white mb-4 px-4 sticky-top d-flex align-items-center justify-content-between" style="height: 75px; box-shadow: 0 4px 6px -1px rgba(0,0,0,0.03);">
                <div>
                    <h4 class="mb-0 fw-bold text-dark" style="letter-spacing: -0.5px;">
                        @(CurrentUser.IsInstructor() ? "Instructor Portal" : "Student Dashboard")
                    </h4>
                    <p class="mb-0 text-muted small">Welcome back, let's achieve greatness today.</p>
                </div>

                <div class="d-flex align-items-center gap-3">
                    <button class="btn btn-light rounded-circle shadow-sm" style="width: 42px; height: 42px;" title="AI Assistant" onclick="toggleChatWindow()">
                         <i class="bi bi-robot text-primary"></i>
                    </button>
                    <button class="btn btn-light position-relative rounded-circle shadow-sm" style="width: 42px; height: 42px;" title="Notifications">
                        <i class="bi bi-bell"></i>
                        <span class="position-absolute top-10 start-90 translate-middle p-1 bg-danger border border-light rounded-circle"></span>
                    </button>
                    <div class="dropdown">
                        <a href="#" class="d-flex align-items-center text-decoration-none dropdown-toggle ms-2" id="dropdownUser" data-bs-toggle="dropdown" aria-expanded="false">
                            <img src="https://ui-avatars.com/api/?name=@displayName&background=f3f4f6&color=4f46e5&bold=true"
                                 class="rounded-circle shadow-sm" width="42" height="42">
                        </a>
                        <ul class="dropdown-menu dropdown-menu-end shadow-sm border-0" aria-labelledby="dropdownUser">
                            <li><a class="dropdown-item" href="#"><i class="bi bi-person me-2"></i>Profile</a></li>
                            <li><a class="dropdown-item" href="#"><i class="bi bi-gear me-2"></i>Settings</a></li>
                            <li><hr class="dropdown-divider"></li>
                            <li><a class="dropdown-item text-danger" href="/Users/Logout"><i class="bi bi-box-arrow-right me-2"></i>Sign out</a></li>
                        </ul>
                    </div>
                </div>
            </nav>
        }

        @if (userId == 0)
        {
            <div class="container-fluid px-0">
                @RenderBody()
            </div>
        }
        else
        {
            <div class="container-fluid px-4 pb-5">
                @RenderBody()
            </div>
        }
    </div>

    <!-- AI CHAT FLOAT BUTTON -->
    @if (userId != 0)
    {
        <div class="ai-chat-float">
            <button class="btn btn-primary btn-lg rounded-circle shadow-lg text-white"
                    onclick="toggleChatWindow()" style="width: 60px; height: 60px;">
                <i class="bi bi-stars fs-4"></i>
            </button>
        </div>

        <!-- Chat Window -->
        <div class="chat-window d-flex flex-column" id="chatWindow" style="display: none !important;">
            <div class="bg-primary text-white p-3 rounded-top d-flex justify-content-between align-items-center">
                <div class="d-flex align-items-center gap-2">
                    <h5 class="mb-0 fw-bold"><i class="bi bi-robot me-1"></i>AI Tutor</h5>
                    <select id="chatLanguage" class="form-select form-select-sm bg-white text-dark border-0 rounded-pill ms-2" style="width: auto; padding-right: 2rem;">
                        <option value="Amharic">አማርኛ (Amharic)</option>
                        <option value="Oromo">Afaan Oromo</option>
                        <option value="English">English</option>
                    </select>
                </div>
                <button class="btn-close btn-close-white" onclick="toggleChatWindow()"></button>
            </div>
            <div id="chatMessages" class="flex-grow-1 overflow-auto p-3" style="background-color: #f8f9fc;">
                <div class="text-center text-muted small mt-2">Ask me anything about your lessons in your preferred language!</div>
            </div>
            <div class="p-3 border-top bg-white rounded-bottom">
                <div class="input-group">
                    <input type="text" id="chatInput" class="form-control" placeholder="Ask AI...">
                    <button class="btn btn-primary" onclick="sendMessage()"><i class="bi bi-send-fill"></i></button>
                    <button class="btn btn-outline-secondary ms-2 rounded-circle" id="talkBtn" onclick="toggleSpeech()" title="Enable Voice">
                        <i class="bi bi-volume-up-fill"></i>
                    </button>
                </div>
            </div>
        </div>
    }

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        let voiceEnabled = false;

        function toggleSpeech() {
            voiceEnabled = !voiceEnabled;
            const btn = document.getElementById('talkBtn');
            if(voiceEnabled) {
                btn.classList.remove('btn-outline-secondary');
                btn.classList.add('btn-success');
                btn.innerHTML = '<i class="bi bi-volume-up-fill"></i>';
            } else {
                btn.classList.remove('btn-success');
                btn.classList.add('btn-outline-secondary');
                btn.innerHTML = '<i class="bi bi-volume-mute-fill"></i>';
                window.speechSynthesis.cancel();
            }
        }

        function playVoice(text, lang) {
            if(!voiceEnabled) return;

            window.speechSynthesis.cancel();
            let utterance = new SpeechSynthesisUtterance(text);
            
            // Map languages approximately
            if(lang === "Amharic") utterance.lang = 'am-ET';
            else if(lang === "Oromo") utterance.lang = 'om-ET'; // May fallback if not supported natively
            else utterance.lang = 'en-US';

            window.speechSynthesis.speak(utterance);
        }

        window.currentLessonId = 0;

        function toggleChatWindow() {
            var chatWindow = document.getElementById('chatWindow');
            if (chatWindow.style.display === 'none' || chatWindow.style.display === '') {
                chatWindow.style.display = 'flex';
                chatWindow.style.setProperty("display", "flex", "important");
                // Fetch history if we have a lessonId context or even if not we could try. We will just load current history for lesson
                if(window.currentLessonId) {
                    loadChatHistory(window.currentLessonId);
                }
            } else {
                chatWindow.style.setProperty("display", "none", "important");
                window.speechSynthesis.cancel();
            }
        }

        function loadChatHistory(lessonId) {
            $.get('/AiinteractionFeedbacks/GetChatHistory?lessonId=' + lessonId, function(res) {
                if(res && res.success && res.history && res.history.length > 0) {
                    var msgs = document.getElementById('chatMessages');
                    msgs.innerHTML = '<div class="text-center text-muted small mt-2">Previous chat history loaded.</div>';
                    res.history.forEach(function(item) {
                        msgs.innerHTML += `<div class="d-flex justify-content-end mb-3"><div class="bg-primary text-white p-2 rounded-3" style="max-width: 80%;">${item.question}</div></div>`;
                        msgs.innerHTML += `<div class="d-flex justify-content-start mb-3"><div class="bg-light border text-dark p-2 rounded-3" style="max-width: 80%;">${item.answer}</div></div>`;
                    });
                    msgs.scrollTop = msgs.scrollHeight;
                }
            });
        }

        function openAiForLesson(id, title) {
            window.currentLessonId = id;
            var chatWindow = document.getElementById('chatWindow');
            if (chatWindow && chatWindow.style.display === 'none') {
                toggleChatWindow();
            }
            document.getElementById('chatInput').value = `Can you explain the lesson '${title}'?`;
            sendMessage();
        }

        function sendMessage() {
            var input = document.getElementById('chatInput');
            var msg = input.value;
            var lang = document.getElementById('chatLanguage').value;

            if (!msg) return;

            var msgs = document.getElementById('chatMessages');
            // Add user message
            msgs.innerHTML += `<div class="d-flex justify-content-end mb-3"><div class="bg-primary text-white p-2 rounded-3" style="max-width: 80%;">${msg}</div></div>`;
            input.value = '';
            msgs.scrollTop = msgs.scrollHeight;

            // Add typing indicator
            var typingId = "typing-" + Date.now();
            msgs.innerHTML += `<div id="${typingId}" class="d-flex justify-content-start mb-3"><div class="bg-light border text-dark p-2 rounded-3 text-muted small">AI is thinking in ${lang}...</div></div>`;
            msgs.scrollTop = msgs.scrollHeight;

            // Call real backend endpoint for AI Interaction
            $.ajax({
                url: '/AiinteractionFeedbacks/AskQuestion',
                type: 'POST',
                headers: { "RequestVerificationToken": $('input[name="__RequestVerificationToken"]').val() || "" },
                data: {
                    lessonId: window.currentLessonId || 0,
                    questionText: msg,
                    forcedLanguage: lang
                },
                success: function(response) {
                    document.getElementById(typingId).remove();
                    if(response.success) {
                        msgs.innerHTML += `<div class="d-flex justify-content-start mb-3"><div class="bg-light border text-dark p-2 rounded-3" style="max-width: 80%;">${response.answer}</div></div>`;
                        msgs.scrollTop = msgs.scrollHeight;
                        playVoice(response.answer, lang);
                    } else {
                        msgs.innerHTML += `<div class="d-flex justify-content-start mb-3"><div class="bg-light border border-danger text-dark p-2 rounded-3" style="max-width: 80%;">${response.message}</div></div>`;
                        msgs.scrollTop = msgs.scrollHeight;
                    }
                },
                error: function() {
                    document.getElementById(typingId).remove();
                    msgs.innerHTML += `<div class="d-flex justify-content-start mb-3"><div class="bg-light border border-danger text-dark p-2 rounded-3" style="max-width: 80%;">I'm sorry, I encountered a network error.</div></div>`;
                    msgs.scrollTop = msgs.scrollHeight;
                }
            });
        }

        // Allow pressing Enter to send message
        document.addEventListener('DOMContentLoaded', function() {
            var chatInput = document.getElementById('chatInput');
            if (chatInput) {
                chatInput.addEventListener('keypress', function (e) {
                    if (e.key === 'Enter') {
                        sendMessage();
                    }
                });
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>