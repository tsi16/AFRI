@model Afri.Models.Lesson

@{
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid py-4 bg-light min-vh-100">
    <div class="row g-4">
        <!-- Sidebar Curriculum Navigation -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 sticky-top" style="top: 20px;">
                <div class="card-header bg-white border-bottom p-4">
                    <h5 class="fw-bold mb-0">@Model.Topic.Subject.Name</h5>
                    <p class="text-muted small mb-0">@Model.Topic.Title</p>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush">
                        @foreach (var l in Model.Topic.Lessons)
                        {
                            <a href="/Lessons/ViewLesson/@l.Id" 
                               class="list-group-item list-group-item-action py-3 px-4 @(l.Id == Model.Id ? "bg-primary text-white pointer-events-none" : "text-dark")">
                                <i class="bi @(l.Id == Model.Id ? "bi-play-circle-fill" : "bi-journal-check") me-2"></i>
                                @l.Title
                            </a>
                        }
                        
                        @if (Model.Topic.Quizzes.Any())
                        {
                            <div class="list-group-item bg-light text-center py-2 border-top">
                                <span class="badge bg-warning text-dark"><i class="bi bi-star-fill"></i> Topic Quiz Available</span>
                            </div>
                            @foreach (var q in Model.Topic.Quizzes)
                            {
                                <a href="/Quizs/TakeQuiz?quizId=@q.Id" class="list-group-item list-group-item-action py-3 px-4 text-success fw-bold">
                                    <i class="bi bi-patch-question-fill me-2"></i> @q.Title
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
        </div>

        <!-- Main Lesson Content Area -->
        <div class="col-md-9">
            <div class="card border-0 shadow-sm rounded-4 mb-4">
                <div class="card-header bg-white p-4 d-flex justify-content-between align-items-center">
                    <div>
                        <span class="badge bg-primary rounded-pill mb-2">Lesson</span>
                        <h2 class="fw-bold mb-0">@Model.Title</h2>
                    </div>
                    @if (Model.IsDownloadable == true)
                    {
                        <button class="btn btn-outline-primary rounded-pill">
                            <i class="bi bi-cloud-arrow-down me-2"></i> Download PDF
                        </button>
                    }
                </div>
                <div class="card-body p-5 fs-5" style="line-height: 1.8;">
                    <div class="lesson-content">
                        @if (!string.IsNullOrEmpty(Model.Content))
                        {
                            @Html.Raw(Model.Content.Replace("\n", "<br/>"))
                        }
                        else
                        {
                            <div class="alert alert-info text-center py-5">
                                <i class="bi bi-info-circle display-4 d-block mb-3"></i>
                                Content is currently being prepared for this lesson. Please check back later!
                            </div>
                        }
                    </div>
                </div>
            </div>

            <!-- Next Steps / AI Section -->
            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
                        <div class="card-body p-4 text-center">
                            <i class="bi bi-robot display-4 mb-3 d-block opacity-75"></i>
                            <h4 class="fw-bold">Stuck? Ask the AI Tutor</h4>
                            <p class="mb-4 opacity-75">Get instant explanations and translations for this lesson.</p>
                            <button class="btn btn-light rounded-pill px-4 fw-bold text-primary" onclick="openAiForLesson(@Model.Id, '@Model.Title')">
                                Ask a Question
                            </button>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    @if (Model.Topic.Quizzes.Any())
                    {
                        <div class="card border-0 shadow-sm rounded-4 h-100 bg-success text-white">
                            <div class="card-body p-4 text-center">
                                <i class="bi bi-trophy display-4 mb-3 d-block opacity-75"></i>
                                <h4 class="fw-bold">Ready to test yourself?</h4>
                                <p class="mb-4 opacity-75">Take the topic quiz and earn points for your leaderboard!</p>
                                @if(Model.Topic.Quizzes.FirstOrDefault() != null)
                                {
                                    <a href="/Quizs/TakeQuiz?quizId=@Model.Topic.Quizzes.FirstOrDefault()?.Id" class="btn btn-light rounded-pill px-4 fw-bold text-success">
                                        Start Quiz Now
                                    </a>
                                }
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
