@model Afri.Models.Quiz
@{
    ViewData["Title"] = Model.Title;
}

<div class="container py-4">
    <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
        <div class="card-header bg-primary text-white p-4">
            <div class="d-flex justify-content-between align-items-center">
                <h3 class="mb-0 fw-bold">@Model.Title</h3>
                @if (Model.TimeLimit.HasValue)
                {
                    <span class="badge bg-white text-primary fs-6">
                        <i class="bi bi-clock me-1"></i> @Model.TimeLimit mins
                    </span>
                }
            </div>
        </div>

        <form asp-action="SubmitQuiz" method="post">
            <input type="hidden" name="quizId" value="@Model.Id" />

            <div class="card-body p-4 bg-light">
                @foreach (var question in Model.QuizQuestions)
                {
                    <div class="card border-0 shadow-sm rounded-3 mb-4">
                        <div class="card-body p-4">
                            <h5 class="fw-bold mb-3 d-flex align-items-center">
                                <span class="badge bg-secondary me-2">@question.QuestionType</span> 
                                <span class="text-dark">@question.QuestionText</span>
                            </h5>

                            <div class="row g-3">
                                @if (question.QuestionType == "Short Answer" || question.QuestionType == "Fill in the Blank")
                                {
                                    <div class="col-12">
                                        <input type="text" class="form-control form-control-lg" name="textAnswers[@question.Id]" placeholder="Type your answer here..." required />
                                    </div>
                                }
                                else if (question.QuestionType == "Multiple Answer")
                                {
                                    @foreach (var option in question.QuizOptions)
                                    {
                                        <div class="col-md-6">
                                            <input type="checkbox" class="btn-check"
                                                   name="selectedOptions[@question.Id]"
                                                   id="option-@option.Id"
                                                   value="@option.Id">
                                            <label class="btn btn-outline-primary w-100 py-3 text-start rounded-3" for="option-@option.Id">
                                                <i class="bi bi-square-fill me-2 checkbox-icon"></i> @option.OptionText
                                            </label>
                                        </div>
                                    }
                                }
                                else
                                {
                                    @foreach (var option in question.QuizOptions)
                                    {
                                        <div class="col-md-6">
                                            <input type="radio" class="btn-check"
                                                   name="singleOptions[@question.Id]"
                                                   id="option-@option.Id"
                                                   value="@option.Id" required>
                                            <label class="btn btn-outline-primary w-100 py-3 text-start rounded-3" for="option-@option.Id">
                                                <i class="bi bi-circle-fill me-2 radio-icon"></i> @option.OptionText
                                            </label>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>

            <div class="card-footer bg-white border-0 p-4">
                <button type="submit" class="btn btn-primary btn-lg w-100 rounded-pill shadow">
                    Finish Assessment
                </button>
            </div>
        </form>
    </div>
</div>