                </div>

                <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); backdrop-filter: blur(20px); border-radius: 24px; padding: 40px; text-align: center;">
                    <div style="width: 80px; height: 80px; background: #2563eb; border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
                        <i class="bi bi-cpu" style="font-size: 2rem;"></i>
                    </div>
                    <h4 style="margin-bottom: 20px;">AfriLearn AI</h4>
                    <div style="display: flex; flex-direction: column; gap: 10px; text-align: left;">
                        <div style="background: rgba(255,255,255,0.1); padding: 10px 15px; border-radius: 12px; font-size: 0.9rem;">
                            <small style="color: #c5a059;">አማርኛ</small><br/>ፊዚክስ ምንድን ነው?
                        </div>
                        <div style="background: #2563eb; padding: 10px 15px; border-radius: 12px; font-size: 0.9rem; align-self: flex-end;">
                            <small>AI Tutor</small><br/>Physics is the study of matter...
                        </div>
                    </div>
                </div>
            </div>
        </section>

        <section id="subjects" style="padding: 100px 0; background: #f8fafc; color: #0f172a;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; text-align: center;">
                <h2 style="font-size: 2.5rem; font-weight: 800; margin-bottom: 48px;">12+ Subjects Covered</h2>
                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 20px;">
                    @{
                        var subjects = new[] { 
                            new { Name = "Mathematics", Icon = "bi-calculator", Color = "#2563eb" },
                            new { Name = "Biology", Icon = "bi-activity", Color = "#10b981" },
                            new { Name = "Physics", Icon = "bi-lightning-charge", Color = "#f59e0b" },
                            new { Name = "Chemistry", Icon = "bi-eyedropper", Color = "#8b5cf6" },
                            new { Name = "History", Icon = "bi-book", Color = "#ef4444" },
                            new { Name = "ICT", Icon = "bi-cpu", Color = "#64748b" }
                        };
                    }
                    @foreach (var s in subjects)
                    {
                        <div style="background: white; padding: 30px; border-radius: 16px; box-shadow: 0 4px 6px rgba(0,0,0,0.05); transition: transform 0.2s;" onmouseover="this.style.transform='translateY(-5px)'" onmouseout="this.style.transform='translateY(0)'">
                            <div style="font-size: 2rem; color: @s.Color; margin-bottom: 10px;"><i class="bi @s.Icon"></i></div>
                            <div style="font-weight: bold;">@s.Name</div>
                            <div style="font-size: 0.8rem; color: #64748b;">Grade 9-12</div>
                        </div>
                    }
                </div>
            </div>
        </section>

        <section id="pricing" style="padding: 100px 0; background: #0f172a; color: white;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div style="text-align: center; margin-bottom: 60px;">
                    <h2 style="font-size: 2.5rem; font-weight: 800;">Choose Your Plan</h2>
                    <p style="color: rgba(255,255,255,0.6);">Transparent pricing for every student.</p>
                </div>
                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px;">
                    <div style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1); padding: 40px; border-radius: 24px;">
                        <h3 style="margin-bottom: 10px;">Basic</h3>
                        <div style="font-size: 2rem; font-weight: 800; margin-bottom: 20px;">Free</div>
                        <ul style="list-style: none; padding: 0; margin-bottom: 30px; color: rgba(255,255,255,0.7);">
                            <li><i class="bi bi-check2"></i> 12+ Subjects Access</li>
                            <li><i class="bi bi-check2"></i> 10 AI Queries / Day</li>
                        </ul>
                        <a href="#" style="display: block; text-align: center; padding: 12px; border: 1px solid #fff; border-radius: 8px; color: white; text-decoration: none;">Get Started</a>
                    </div>
                    <div style="background: white; color: #0f172a; padding: 40px; border-radius: 24px; position: relative; transform: scale(1.05);">
                        <span style="position: absolute; top: -15px; left: 50%; transform: translateX(-50%); background: #c5a059; color: white; padding: 5px 15px; border-radius: 20px; font-size: 0.8rem; font-weight: bold;">MOST POPULAR</span>
                        <h3 style="margin-bottom: 10px;">Pro Monthly</h3>
                        <div style="font-size: 2rem; font-weight: 800; margin-bottom: 20px;">$5.99 <small style="font-size: 1rem;">/mo</small></div>
                        <ul style="list-style: none; padding: 0; margin-bottom: 30px;">
                            <li><i class="bi bi-check2"></i> Unlimited AI Queries</li>
                            <li><i class="bi bi-check2"></i> Past National Exams</li>
                            <li><i class="bi bi-check2"></i> Offline Notes</li>
                        </ul>
                        <a href="#" style="display: block; text-align: center; padding: 12px; background: #2563eb; color: white; border-radius: 8px; text-decoration: none; font-weight: bold;">Go Pro Now</a>
                    </div>
                </div>
            </div>
        </section>



        <section style="background: #fff; padding: 28px 0; border-bottom: 1px solid #f1f5f9;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div style="display: flex; align-items: center; justify-content: center; gap: 48px; flex-wrap: wrap;">
                    <span style="color: #94a3b8; fontSize: 0.85rem; font-weight: 600; letter-spacing: 1px;">
                        TRUSTED BY STUDENTS ACROSS ETHIOPIA
                    </span>
                    <div style="display: flex; align-items: center; gap: 8px; color: #475569;">
                        <i class="bi bi-shield-check" style="color: #2563eb; font-size: 1.1rem;"></i>
                        <span style="font-size: 0.9rem; font-weight: 600;">Curriculum Aligned</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; color: #475569;">
                        <i class="bi bi-translate" style="color: #2563eb; font-size: 1.1rem;"></i>
                        <span style="font-size: 0.9rem; font-weight: 600;">3 Languages</span>
                    </div>
                    <div style="display: flex; align-items: center; gap: 8px; color: #475569;">
                        <i class="bi bi-award" style="color: #2563eb; font-size: 1.1rem;"></i>
                        <span style="font-size: 0.9rem; font-weight: 600;">Grade 9–12</span>
                    </div>
                </div>
            </div>
        </section>

        <section id="features" style="padding: 100px 0; background: #f8fafc;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div style="text-align: center; margin-bottom: 64px;">
                    <div class="section-badge"><i class="bi bi-stars"></i> Why AfriLearn</div>
                    <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #0f172a; margin-bottom: 16px;">
                        Everything You Need to <span class="text-gradient">Excel in School</span>
                    </h2>
                    <p style="color: #64748b; font-size: 1.1rem; max-width: 560px; margin: 0 auto;">
                        Built specifically for Ethiopian students, with the tools and language support you need to succeed.
                    </p>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;">
                    <div class="feature-card" style="padding: 32px; background: #fff; border-radius: 24px; border: 1px solid #e2e8f0;">
                        <div style="width: 56px; height: 56px; background: rgba(37,99,235,0.08); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <i class="bi bi-translate" style="color: #2563eb; font-size: 1.5rem;"></i>
                        </div>
                        <h5 style="font-weight: 700; color: #0f172a;">Learn in Your Language</h5>
                        <p style="color: #64748b; font-size: 0.95rem;">Study Biology, Physics, and Math directly in Amharic or Afan Oromo. No translation needed.</p>
                    </div>

                    <div class="feature-card" style="padding: 32px; background: #fff; border-radius: 24px; border: 1px solid #e2e8f0;">
                        <div style="width: 56px; height: 56px; background: rgba(197,160,89,0.1); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <i class="bi bi-robot" style="color: #c5a059; font-size: 1.5rem;"></i>
                        </div>
                        <h5 style="font-weight: 700; color: #0f172a;">24/7 AI Tutor</h5>
                        <p style="color: #64748b; font-size: 0.95rem;">Our AI understands your local curriculum and context, available any time you need help.</p>
                    </div>

                    <div class="feature-card" style="padding: 32px; background: #fff; border-radius: 24px; border: 1px solid #e2e8f0;">
                        <div style="width: 56px; height: 56px; background: rgba(245,158,11,0.08); border-radius: 16px; display: flex; align-items: center; justify-content: center; margin-bottom: 20px;">
                            <i class="bi bi-download" style="color: #f59e0b; font-size: 1.5rem;"></i>
                        </div>
                        <h5 style="font-weight: 700; color: #0f172a;">Offline Notes</h5>
                        <p style="color: #64748b; font-size: 0.95rem;">Download summarized notes and study offline. Perfect for areas with limited internet.</p>
                    </div>
                </div>
            </div>
        </section>


        <section id="how-it-works" style="padding: 100px 0; background: #fff;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div style="text-align: center; margin-bottom: 64px;">
                    <div class="section-badge"><i class="bi bi-map"></i> How It Works</div>
                    <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #0f172a;">
                        Start Learning in <span class="text-gradient">4 Simple Steps</span>
                    </h2>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 32px;">
                    <div style="text-align: center;">
                        <div style="width: 72px; height: 72px; background: linear-gradient(135deg, #2563eb, #1e40af); border-radius: 50%; display: flex; align-items: center; justify-content: center; margin: 0 auto 20px; box-shadow: 0 8px 24px rgba(37,99,235,0.3);">
                            <i class="bi bi-person-plus" style="color: #fff; font-size: 1.6rem;"></i>
                        </div>
                        <div style="font-size: 0.75rem; font-weight: 800; color: #2563eb; letter-spacing: 2px; margin-bottom: 8px;">STEP 01</div>
                        <h5 style="font-weight: 700; color: #0f172a;">Create Account</h5>
                        <p style="color: #64748b; font-size: 0.9rem;">Sign up in seconds. No credit card required.</p>
                    </div>
                </div>
            </div>
        </section>

        <section id="subjects" style="padding: 100px 0; background: #f8fafc;">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px;">
                <div style="text-align: center; margin-bottom: 64px;">
                    <div class="section-badge"><i class="bi bi-collection"></i> Subjects</div>
                    <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #0f172a;">
                        12+ Subjects, <span class="text-gradient">All Grades Covered</span>
                    </h2>
                </div>

                <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(180px, 1fr)); gap: 16px;">
                    <div class="feature-card" style="padding: 24px 20px; text-align: center; background: #fff; border-radius: 20px;">
                        <div style="width: 52px; height: 52px; background: rgba(37,99,235,0.1); border-radius: 14px; display: flex; align-items: center; justify-content: center; margin: 0 auto 14px;">
                            <i class="bi bi-calculator" style="color: #2563eb; font-size: 1.4rem;"></i>
                        </div>
                        <div style="font-weight: 700; color: #0f172a; font-size: 0.95rem;">Mathematics</div>
                        <div style="font-size: 0.75rem; color: #94a3b8;">Grade 9–12</div>
                    </div>
                </div>
            </div>
        </section>



<section id="pricing" style="padding: 100px 0; background: #0f172a; position: relative; overflow: hidden;">
    <div style="position: absolute; top: 20%; left: 50%; transform: translateX(-50%); width: 800px; height: 400px; background: radial-gradient(ellipse, rgba(37,99,235,0.15) 0%, transparent 70%); pointer-events: none;"></div>

    <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; position: relative; z-index: 1;">
        <div style="text-align: center; margin-bottom: 64px;">
            <div class="section-badge gold"><i class="bi bi-gem"></i> Pricing</div>
            <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #fff; margin-bottom: 16px;">
                Simple Plans for <span class="text-gradient-gold">Every Student</span>
            </h2>
            <p style="color: rgba(255,255,255,0.55); font-size: 1.1rem; max-width: 500px; margin: 0 auto;">
                Invest in your education. Higher grades are just one click away.
            </p>
        </div>

        <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; align-items: center;">
            @foreach (var plan in plans)
            {
                <div class="pricing-card @(plan.Featured ? "featured" : "")" 
                     style="padding: 36px; background: @(plan.Featured ? "linear-gradient(135deg, #2563eb 0%, #1e40af 100%)" : "rgba(255,255,255,0.04)"); border: @(plan.Featured ? "none" : "1px solid rgba(255,255,255,0.1)"); position: relative; border-radius: 24px;">
                    
                    @if (!string.IsNullOrEmpty(plan.Badge))
                    {
                        <div style="position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: #c5a059; color: #0f172a; border-radius: 50px; padding: 4px 18px; font-size: 0.72rem; font-weight: 800; white-space: nowrap;">
                            @plan.Badge
                        </div>
                    }

                    <div style="margin-bottom: 8px;">
                        <span style="font-size: 0.8rem; font-weight: 700; color: rgba(255,255,255,0.6); letter-spacing: 1px;">@plan.Name.ToUpper()</span>
                    </div>

                    <div style="display: flex; align-items: baseline; gap: 4px; margin-bottom: 8px;">
                        <span style="font-size: 3rem; font-weight: 900; color: #fff; line-height: 1;">@plan.Price</span>
                        <span style="color: rgba(255,255,255,0.4); font-size: 0.9rem;">@plan.Period</span>
                    </div>

                    <p style="color: rgba(255,255,255,0.5); font-size: 0.9rem; margin-bottom: 28px;">@plan.Desc</p>

                    <div style="margin-bottom: 32px;">
                        @foreach (var feature in plan.Features)
                        {
                            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                                <i class="bi bi-check-circle-fill" style="color: @(plan.Featured ? "#fff" : "#10b981");"></i>
                                <span style="font-size: 0.9rem; color: rgba(255,255,255,0.85);">@feature</span>
                            </div>
                        }
                        @foreach (var ex in plan.Excluded)
                        {
                            <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 12px;">
                                <i class="bi bi-x-circle" style="color: rgba(255,255,255,0.2);"></i>
                                <span style="font-size: 0.9rem; color: rgba(255,255,255,0.25);">@ex</span>
                            </div>
                        }
                    </div>

                    <a href="/Users/Signup" class="btn-primary-afri" 
                       style="display: block; text-align: center; background: @(plan.Featured ? "#fff" : "rgba(255,255,255,0.1)"); color: @(plan.Featured ? "#2563eb" : "#fff"); border-radius: 50px; padding: 14px; text-decoration: none; font-weight: 700;">
                        @plan.Cta
                    </a>
                </div>
            }
        </div>
    </div>
</section>

<section id="faq" style="padding: 100px 0; background: #f8fafc;">
    <div style="max-width: 800px; margin: 0 auto; padding: 0 24px;">
        <div style="text-align: center; margin-bottom: 64px;">
            <div class="section-badge"><i class="bi bi-question-circle"></i> FAQ</div>
            <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #0f172a;">
                Frequently Asked <span class="text-gradient">Questions</span>
            </h2>
        </div>

        <div class="accordion" id="afriFaq">
            @{
                var faqs = new[] {
                    new { Q = "Is AfriLearn really free to use?", A = "Yes! The Basic plan is completely free forever. You get access to all 12+ subjects and 10 AI queries per day at no cost." },
                    new { Q = "Which languages does the AI tutor support?", A = "Our AI tutor fully supports Amharic (አማርኛ), Afan Oromo, and English." }
                };
            }

            @for (int i = 0; i < faqs.Length; i++)
            {
                <div class="faq-item" style="background: #fff; margin-bottom: 12px; border-radius: 12px; border: 1px solid #e2e8f0; overflow: hidden;">
                    <button class="faq-btn" onclick="toggleFaq(@i)" style="width: 100%; padding: 20px 24px; background: none; border: none; cursor: pointer; display: flex; justify-content: space-between; align-items: center; text-align: left;">
                        <span style="font-weight: 600; color: #0f172a;">@faqs[i].Q</span>
                        <i class="bi bi-chevron-down" id="icon-@i" style="color: #2563eb; transition: 0.3s;"></i>
                    </button>
                    <div id="faq-@i" style="display: none; padding: 0 24px 20px; color: #64748b; font-size: 0.95rem; line-height: 1.75;">
                        @faqs[i].A
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<section style="padding: 80px 24px; background: #fff;">
    <div style="max-width: 900px; margin: 0 auto; background: linear-gradient(135deg, #0f172a 0%, #1e293b 100%); border-radius: 32px; padding: 72px 48px; text-align: center; position: relative; overflow: hidden;">
        <div style="position: absolute; top: -60px; right: -60px; width: 200px; height: 200px; background: rgba(37,99,235,0.15); border-radius: 50%;"></div>
        <div style="position: relative; z-index: 1;">
            <div class="section-badge gold" style="margin-bottom: 24px;"><i class="bi bi-rocket-takeoff"></i> Start Today</div>
            <h2 style="font-size: clamp(2rem, 4vw, 3rem); font-weight: 900; color: #fff; margin-bottom: 20px;">
                Ready to Transform Your <span class="text-gradient-gold">Academic Journey?</span>
            </h2>
            <div style="display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; margin-top: 40px;">
                <a href="/Users/Signup" class="btn-gold" style="padding: 12px 30px; text-decoration: none;">Create Free Account</a>
                <a href="/Users/Signin" class="btn-outline-afri" style="padding: 12px 30px; text-decoration: none;">Sign In</a>
            </div>
        </div>
    </div>
</section>

        <footer style="background: #0f172a; padding: 64px 24px 32px; color: rgba(255,255,255,0.6);">
            <div style="max-width: 1200px; margin: 0 auto;">
                <div style="display: grid; grid-template-columns: 2fr 1fr 1fr 1fr; gap: 48px; margin-bottom: 48px;">
                    <div>
                        <div style="display: flex; align-items: center; gap: 10px; margin-bottom: 16px;">
