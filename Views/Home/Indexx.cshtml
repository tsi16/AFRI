@using Afri.Utilities
@inject Afri.Utilities.CurrentUser CurrentUser
@{
    ViewData["Title"] = "AfriLearn | Ethiopia's #1 AI Learning Platform";
    // ViewData["Title"] = "Welcome to AfriLearn";
    int userId = CurrentUser.GetUserId();

    var plans = new[] {
        new { Name = "Basic", Price = "Free", Period = "forever", Desc = "Perfect for getting started", Featured = false, Badge = "", Cta = "Get Started Free",
              Features = new[] { "All 12+ Subjects Access", "10 AI Queries per Day", "Practice Quizzes" },
              Excluded = new[] { "Offline Notes Download", "Unlimited AI Help", "Priority Support" } },
        new { Name = "Pro Monthly", Price = "$5.99", Period = "/month", Desc = "For serious exam preparation", Featured = true, Badge = "MOST POPULAR", Cta = "Go Pro Now",
              Features = new[] { "All 12+ Subjects Access", "Unlimited AI Queries", "Practice Quizzes + Past Exams", "Offline Notes Download", "Priority Support", "Progress Analytics" },
              Excluded = new string[] {} },
        new { Name = "Pro Annual", Price = "$49", Period = "/year", Desc = "Best value — save 32%", Featured = false, Badge = "BEST VALUE", Cta = "Save 32% Annually",
              Features = new[] { "Everything in Pro Monthly", "32% Savings vs Monthly", "Early Access to New Features", "Dedicated Study Planner", "Parent Progress Reports", "Certificate of Completion" },
              Excluded = new string[] {} }
    };
}


@if (userId == 0)
{
    <div style="font-family: var(--font-inter, Inter, system-ui, sans-serif); background: #0f172a; color: white;">
        
        <nav class="navbar-afri" style="padding: 16px 0; position: sticky; top: 0; z-index: 1000; background: rgba(15, 23, 42, 0.9); backdrop-filter: blur(10px);">
            <div style="max-width: 1200px; margin: 0 auto; padding: 0 24px; display: flex; align-items: center; justify-content: space-between;">
                <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="width: 38px; height: 38px; background: linear-gradient(135deg, #2563eb, #c5a059); border-radius: 10px; display: flex; align-items: center; justify-content: center;">
                        <i class="bi bi-mortarboard-fill" style="color: #fff; font-size: 18px;"></i>
                    </div>
                    <span style="color: #fff; font-weight: 800; font-size: 1.25rem; letter-spacing: -0.5px;">Afri<span style="color: #c5a059;">Learn</span></span>
                </div>

                <div class="hidden-mobile" style="display: flex; gap: 32px;">
                    @foreach (var link in new[] { "Features", "Subjects", "Pricing", "FAQ" })
                    {
                        <a href="#@link.ToLower()" style="color: rgba(255,255,255,0.7); text-decoration: none; font-size: 0.9rem; font-weight: 500;">@link</a>
                    }
                </div>

                <div style="display: flex; gap: 12px;">
                    <a href="/Users/Signin" style="color: #fff; text-decoration: none; padding: 9px 20px; border-radius: 50px; border: 1px solid rgba(255,255,255,0.2);">Sign In</a>
                    <a href="/Users/Signup" class="btn-primary-afri" style="background: #2563eb; color: #fff; padding: 9px 22px; border-radius: 50px; text-decoration: none;">Get Started Free</a>
                </div>
            </div>
        </nav>

        <section class="hero-section" style="min-height: 92vh; display: flex; align-items: center; padding: 80px 0; position: relative; overflow: hidden;">
