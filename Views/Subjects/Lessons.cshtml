@model Afri.Models.LessonViewModel
@{
    Layout = "_AppLayout";
    ViewData["Title"] = Model.SubjectName;
}

<div class="lessons-page">
    <div class="page-header">
        <div class="breadcrumb">
            <a asp-controller="Subjects" asp-action="Index">Subjects</a>
            <i class="bi bi-chevron-right"></i>
            <span>@Model.SubjectName</span>
        </div>
        <h2>@Model.SubjectName</h2>
        <p>Select a topic to start learning</p>
    </div>

    <div class="topics-list">
        @foreach (var topic in Model.Topics)
        {
            <div class="topic-card @(topic.IsLocked ? "locked" : "")">
                <div class="topic-info">
                    <div class="topic-number">@topic.Id</div>
                    <div class="topic-details">
                        <h3>@topic.Name</h3>
                        <p>@topic.Description</p>
                        <div class="topic-meta">
                            <span><i class="bi bi-book"></i> @topic.LessonCount Lessons</span>
                            @if (!topic.IsLocked && topic.CompletedLessons > 0)
                            {
                                <span class="completed"><i class="bi bi-check-circle"></i> @topic.CompletedLessons/@topic.LessonCount completed</span>
                            }
                        </div>
                    </div>
                </div>
                <div class="topic-progress">
                    @if (topic.IsLocked)
                    {
                        <div class="lock-icon">
                            <i class="bi bi-lock"></i>
                        </div>
                    }
                    else
                    {
                        <div class="progress-bar">
                            <div class="progress-fill" style="width: @topic.Progress%"></div>
                        </div>
                        <span class="progress-text">@topic.Progress%</span>
                        <a asp-controller="Subjects" asp-action="Lessons" asp-route-id="@Model.SubjectId" class="btn btn-primary btn-sm">
                            @if (topic.Progress > 0)
                            {
                                <span>Continue</span>
                            }
                            else
                            {
                                <span>Start</span>
                            }
                        </a>
                    }
                </div>
            </div>
        }
    </div>

    <!-- Download Section - Shows lessons with download options -->
    @if (Model.Topics.Any(t => t.Lessons.Any()))
    {
        <div class="download-section mt-4">
            <h4><i class="bi bi-download me-2"></i>Download for Offline Use</h4>
            <p class="text-muted small">Download lessons to access them without internet. Select your preferred language.</p>

            @foreach (var topic in Model.Topics.Where(t => t.Lessons.Any()))
            {
                <div class="topic-downloads mt-3">
                    <h6 class="fw-bold text-primary">@topic.Name</h6>
                    <div class="row">
                        @foreach (var lesson in topic.Lessons)
                        {
                            <div class="col-md-6 col-lg-4 mb-3">
                                <div class="lesson-download-card border rounded p-3 h-100">
                                    <div class="d-flex justify-content-between align-items-start">
                                        <div>
                                            <h6 class="mb-1">@lesson.Title</h6>
                                            @if (lesson.IsDownloaded)
                                            {
                                                <span class="badge bg-success mb-2"><i class="bi bi-check-circle me-1"></i>Downloaded</span>
                                                <br>
                                                <small class="text-muted">
                                                    Downloaded: @lesson.DownloadedDate?.ToString("MMM dd, yyyy")
                                                    @if (lesson.ExpiryDate.HasValue)
                                                    {
                                                        <span class="text-warning"> | Expires: @lesson.ExpiryDate?.ToString("MMM dd")</span>
                                                    }
                                                </small>
                                            }
                                        </div>
                                        <div>
                                            @if (lesson.IsDownloaded)
                                            {
                                                <button class="btn btn-sm btn-outline-danger" onclick="removeDownload(@lesson.Id)">
                                                    <i class="bi bi-trash"></i>
                                                </button>
                                            }
                                        </div>
                                    </div>

                                    @if (!lesson.IsDownloaded)
                                    {
                                        <button class="btn btn-sm btn-outline-primary mt-2" onclick="openLanguageModal(@lesson.Id, '@lesson.Title')">
                                            <i class="bi bi-download me-1"></i>Download
                                        </button>
                                    }
                                    else
                                    {
                                        <button class="btn btn-sm btn-primary mt-2" onclick="redownloadLesson(@lesson.Id)">
                                            <i class="bi bi-arrow-repeat me-1"></i>Re-download
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- Language Selection Modal -->
<div class="modal fade" id="languageModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow" style="border-radius: 20px;">
            <div class="modal-header border-0">
                <h5 class="modal-title fw-bold">Select Language</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3">Choose the language you want the lesson content translated to:</p>

                <input type="hidden" id="selectedLessonId" value="0" />

                <div id="languageList" class="list-group">
                    <!-- Languages will be loaded here dynamically -->
                    <div class="text-center py-3">
                        <div class="spinner-border spinner-border-sm text-primary" role="status">
                            <span class="visually-hidden">Loading...</span>
                        </div>
                        <p class="small text-muted mt-2">Loading available languages...</p>
                    </div>
                </div>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancel</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Open language selection modal
        function openLanguageModal(lessonId, lessonTitle) {
            $('#selectedLessonId').val(lessonId);
            $('#languageModal .modal-title').text('Download: ' + lessonTitle);
            $('#languageModal').modal('show');

            // Load available translations for this lesson
            loadTranslations(lessonId);
        }

        // Load translations from server
        function loadTranslations(lessonId) {
            $.post('/Subjects/GetTranslations', { lessonId: lessonId }, function(data) {
                var html = '';
                if (data && data.length > 0) {
                    data.forEach(function(lang) {
                        var validatedBadge = lang.isHumanValidated
                            ? '<span class="badge bg-success ms-2">Validated</span>'
                            : '<span class="badge bg-warning ms-2">Auto</span>';

                        html += `
                            <button type="button" class="list-group-item list-group-item-action d-flex justify-content-between align-items-center"
                                    onclick="downloadLesson(${lessonId}, ${lang.languageId}, '${lang.languageName}')">
                                <span>
                                    <i class="bi bi-globe me-2 text-primary"></i>${lang.languageName}
                                    ${validatedBadge}
                                </span>
                                <i class="bi bi-chevron-right text-muted"></i>
                            </button>
                        `;
                    });
                } else {
                    html = '<div class="text-center py-3 text-muted">No translations available</div>';
                }
                $('#languageList').html(html);
            }).fail(function() {
                $('#languageList').html('<div class="text-center py-3 text-danger">Error loading languages</div>');
            });
        }

        // Download lesson with selected language
        function downloadLesson(lessonId, languageId, languageName) {
            $('#languageModal').modal('hide');

            // Show loading indicator
            var btn = event.target;
            var originalText = btn.innerHTML;
            btn.innerHTML = '<span class="spinner-border spinner-border-sm me-1"></span> Downloading...';
            btn.disabled = true;

            // Submit download request
            var form = document.createElement('form');
            form.method = 'POST';
            form.action = '/Subjects/DownloadLesson';

            var lessonInput = document.createElement('input');
            lessonInput.type = 'hidden';
            lessonInput.name = 'lessonId';
            lessonInput.value = lessonId;

            var languageInput = document.createElement('input');
            languageInput.type = 'hidden';
            languageInput.name = 'languageId';
            languageInput.value = languageId;

            form.appendChild(lessonInput);
            form.appendChild(languageInput);
            document.body.appendChild(form);
            form.submit();

            // Reset button after delay
            setTimeout(function() {
                btn.innerHTML = originalText;
                btn.disabled = false;
            }, 3000);
        }

        // Redownload lesson
        function redownloadLesson(lessonId) {
            openLanguageModal(lessonId, 'Re-download Lesson');
        }

        // Remove downloaded lesson
        function removeDownload(lessonId) {
            if (confirm('Are you sure you want to remove this lesson from offline storage?')) {
                $.post('/Subjects/RemoveDownload', { lessonId: lessonId }, function(data) {
                    if (data.success) {
                        // Reload page to show updated status
                        location.reload();
                    } else {
                        alert('Error: ' + data.error);
                    }
                }).fail(function() {
                    alert('Error removing download');
                });
            }
        }
    </script>
}