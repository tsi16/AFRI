@model Afri.Models.Quiz

@{
    ViewData["Title"] = "Manage Questions - " + Model.Title;
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Manage Questions for: <span class="text-primary">@Model.Title</span></h2>
        <div>
            <a asp-action="CreateQuestion" asp-route-quizId="@Model.Id" class="btn btn-primary">
                <i class="bi bi-plus-circle"></i> Add New Question
            </a>
            <a asp-action="Index" class="btn btn-outline-secondary">Back to Quizzes</a>
        </div>
    </div>

    @if (!Model.QuizQuestions.Any())
    {
        <div class="alert alert-info shadow-sm">
            This quiz currently has no questions. Click "Add New Question" to get started!
        </div>
    }
    else
    {
        <div class="accordion shadow-sm" id="questionsAccordion">
            @foreach (var question in Model.QuizQuestions)
            {
                var collapseId = "collapse" + question.Id;
                
                <div class="accordion-item mb-2 border-0 shadow-sm rounded">
                    <h2 class="accordion-header">
                        <button class="accordion-button collapsed fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#@collapseId">
                            Q: @question.QuestionText
                        </button>
                    </h2>
                    <div id="@collapseId" class="accordion-collapse collapse" data-bs-parent="#questionsAccordion">
                        <div class="accordion-body bg-light">
                            <div class="d-flex justify-content-between mb-3">
                                <div>
                                    <span class="badge bg-secondary">Type: @question.QuestionType</span>
                                    <span class="badge bg-info">Difficulty: @question.DifficultyLevel</span>
                                    <span class="badge bg-success">Marks: @question.Marks</span>
                                </div>
                                <form asp-action="DeleteQuestion" method="post" onsubmit="return confirm('Delete this question?');">
                                    <input type="hidden" name="questionId" value="@question.Id" />
                                    <input type="hidden" name="quizId" value="@Model.Id" />
                                    <button type="submit" class="btn btn-sm btn-danger"><i class="bi bi-trash"></i> Delete Question</button>
                                </form>
                            </div>

                            <h6 class="fw-bold border-bottom pb-2">Options:</h6>
                            <ul class="list-group list-group-flush mb-3">
                                @foreach(var option in question.QuizOptions)
                                {
                                    <li class="list-group-item bg-transparent d-flex justify-content-between align-items-center">
                                        <span>
                                            @if(option.IsCorrect == true)
                                            {
                                                <i class="bi bi-check-circle-fill text-success me-2"></i>
                                            }
                                            else
                                            {
                                                <i class="bi bi-circle text-muted me-2"></i>
                                            }
                                            @option.OptionText
                                        </span>
                                    </li>
                                }
                                @if(!question.QuizOptions.Any())
                                {
                                    <li class="list-group-item text-muted bg-transparent fst-italic">No options defined yet.</li>
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>
